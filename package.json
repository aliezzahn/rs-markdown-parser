{
  "name": "rs-markdown-parser",
  "version": "0.2.0",
  "description": "",
  "main": "index.node",
  "scripts": {
    "test": "cargo test",
    "cargo-build": "cargo build --message-format=json-render-diagnostics > cargo.log",
    "cross-build": "cross build --message-format=json-render-diagnostics > cross.log",
    "postcargo-build": "neon dist < cargo.log",
    "postcross-build": "neon dist -m /target < cross.log",
    "debug": "npm run cargo-build --",
    "build": "npm run cargo-build -- --release",
    "cross": "npm run cross-build -- --release"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aliezzahn/rs-markdown-parser.git"
  },
  "keywords": [
    "github",
    "changelog",
    "auto-changelog",
    "auto-changlog-generator"
  ],
  "author": "aliezzahn",
  "bugs": {
    "url": "https://github.com/aliezzahn/rs-markdown-parser/issues"
  },
  "homepage": "https://github.com/aliezzahn/rs-markdown-parser#readme",
  "devDependencies": {
    "@neon-rs/cli": "0.1.82"
  }
}
